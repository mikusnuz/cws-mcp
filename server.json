{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.mikusnuz/cws",
  "description": "MCP server for Chrome Web Store — extension upload, publish, status, and rollout",
  "repository": {
    "url": "https://github.com/mikusnuz/cws-mcp",
    "source": "github"
  },
  "version": "1.4.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "cws-mcp",
      "version": "1.4.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "CWS_CLIENT_ID",
          "description": "Google OAuth2 Client ID for Chrome Web Store API",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "CWS_CLIENT_SECRET",
          "description": "Google OAuth2 Client Secret",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "CWS_REFRESH_TOKEN",
          "description": "OAuth2 Refresh Token",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
