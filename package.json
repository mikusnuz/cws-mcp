  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikusnuz/cws-mcp.git"
  },
  "homepage": "https://github.com/mikusnuz/cws-mcp#readme",
  "bugs": {
    "url": "https://github.com/mikusnuz/cws-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "playwright": "^1.58.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
